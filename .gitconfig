[init]
    defaultBranch = main

[credential]
    helper = libsecret

[core]
    editor = vim
    autocrlf = input
    pager = less -FRX
    excludesFile = ~/.gitignore_global
    # Improve diff for large repos
    preloadIndex = true

[pull]
    rebase = false

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[diff]
    colorMoved = zebra
    algorithm = histogram

[merge]
    conflictstyle = diff3
    tool = vimdiff

[rebase]
    autoStash = true

[rerere]
    enabled = true

[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red
    new = green

[color "status"]
    added = green
    changed = yellow
    untracked = red

# ==============================================================================
# Aliases
# ==============================================================================

[alias]
    # Status and info
    st = status
    ss = status -s
    info = remote -v

    # Branching
    br = branch
    bra = branch -a
    brd = branch -d
    brD = branch -D

    # Checkout
    co = checkout
    cob = checkout -b
    com = checkout main
    cod = checkout develop

    # Commits
    ci = commit
    cm = commit -m
    ca = commit --amend
    can = commit --amend --no-edit

    # Adding
    a = add
    aa = add --all
    ap = add --patch

    # Diffing
    d = diff
    ds = diff --staged
    dc = diff --cached
    dw = diff --word-diff

    # Logging
    lg = log --oneline --graph --decorate
    lga = log --oneline --graph --decorate --all
    ll = log --pretty=format:'%C(yellow)%h%Creset %s %C(green)(%cr) %C(blue)<%an>%Creset' --abbrev-commit
    last = log -1 HEAD --stat

    # Stashing
    stl = stash list
    stp = stash pop
    sta = stash apply
    std = stash drop
    sts = stash show -p

    # Resetting
    unstage = reset HEAD --
    uncommit = reset --soft HEAD~1
    discard = checkout --

    # Remote operations
    f = fetch
    fa = fetch --all
    pl = pull
    ps = push
    pf = push --force-with-lease

    # Rebasing
    rb = rebase
    rbi = rebase -i
    rbc = rebase --continue
    rba = rebase --abort

    # Merging
    m = merge
    ma = merge --abort

    # Utility
    aliases = config --get-regexp alias
    contributors = shortlog -sn
    branches = branch -a
    tags = tag -l
    remotes = remote -v
    wip = commit -am "WIP"
    undo = reset HEAD~1 --mixed
    clean-branches = "!git branch --merged | grep -v '\\*\\|main\\|master\\|develop' | xargs -n 1 git branch -d"

    # Show what changed in the last commit
    whatchanged = log -1 --stat

    # Find commits by message
    find = log --all --grep

    # Show the root directory of the repo
    root = rev-parse --show-toplevel
